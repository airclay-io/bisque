# Normalize line endings for committed text artifacts.
* text=auto eol=lf

# Snapshot artifacts are LF text.
testdata/snapshots.manifest text eol=lf
testdata/snapshots/slices/*.slice text eol=lf

# Captured reference audio (if any is ever committed) is binary.
*.wav binary
*.flac binary
*.png binary
